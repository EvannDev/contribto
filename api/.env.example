# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AES-256 key for encrypting GitHub user tokens in DB (32 random bytes, base64-encoded)
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# AES key for encrypting session cookies via Fiber encryptcookie middleware (32 random bytes, base64-encoded)
# Generate: openssl rand -base64 32
COOKIE_ENCRYPTION_KEY=

# Allowed CORS origin for the frontend
FRONTEND_ORIGIN=http://localhost:3000

# Path to the SQLite database file
DB_PATH=./app.db

# Litestream → Cloudflare R2 replication
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_BUCKET=
LITESTREAM_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# GitHub Personal Access Token for the scan worker (not a user token)
GITHUB_WORKER_PAT=

# HTTP server port
PORT=8080
